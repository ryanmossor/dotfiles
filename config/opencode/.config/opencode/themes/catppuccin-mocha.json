{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "rosewater": "#f5e0dc",
    "flamingo": "#f2cdcd",
    "pink": "#f5c2e7",
    "mauve": "#cba6f7",
    "red": "#f38ba8",
    "maroon": "#eba0ac",
    "peach": "#fab387",
    "yellow": "#f9e2af",
    "green": "#a6e3a1",
    "teal": "#94e2d5",
    "sky": "#89dceb",
    "sapphire": "#74c7ec",
    "blue": "#89b4fa",
    "lavender": "#b4befe",
    "text": "#cdd6f4",
    "subtext1": "#bac2de",
    "subtext0": "#a6adc8",
    "overlay2": "#9399b2",
    "overlay1": "#7f849c",
    "overlay0": "#6c7086",
    "surface2": "#585b70",
    "surface1": "#45475a",
    "surface0": "#313244",
    "base": "#1e1e2e",
    "mantle": "#181825",
    "crust": "#11111b"
  },
    "theme": {
        "primary": { "dark": "blue", "light": "blue" },
        "secondary": { "dark": "mauve", "light": "mauve" },
        "accent": { "dark": "teal", "light": "teal" },
        "error": { "dark": "red", "light": "red" },
        "warning": { "dark": "yellow", "light": "yellow" },
        "success": { "dark": "green", "light": "green" },
        "info": { "dark": "sky", "light": "sky" },

        "text": { "dark": "text", "light": "text" },
        "textMuted": { "dark": "overlay0", "light": "overlay0" },

        "background": { "dark": "base", "light": "base" },
        "backgroundPanel": { "dark": "mantle", "light": "mantle" },
        "backgroundElement": { "dark": "surface0", "light": "surface0" },

        "border": { "dark": "surface0", "light": "surface0" },
        "borderActive": { "dark": "overlay0", "light": "overlay0" },
        "borderSubtle": { "dark": "surface1", "light": "surface1" },

        "diffAdded": { "dark": "green", "light": "green" },
        "diffRemoved": { "dark": "red", "light": "red" },
        "diffContext": { "dark": "overlay1", "light": "overlay1" },
        "diffHunkHeader": { "dark": "overlay2", "light": "overlay2" },
        "diffHighlightAdded": { "dark": "green", "light": "green" },
        "diffHighlightRemoved": { "dark": "red", "light": "red" },
        "diffAddedBg": { "dark": "surface0", "light": "surface0" },
        "diffRemovedBg": { "dark": "surface0", "light": "surface0" },
        "diffContextBg": { "dark": "mantle", "light": "mantle" },
        "diffLineNumber": { "dark": "overlay0", "light": "overlay0" },
        "diffAddedLineNumberBg": { "dark": "surface0", "light": "surface0" },
        "diffRemovedLineNumberBg": { "dark": "surface0", "light": "surface0" },

        "markdownText": { "dark": "text", "light": "text" },
        "markdownHeading": { "dark": "blue", "light": "blue" },
        "markdownLink": { "dark": "lavender", "light": "lavender" },
        "markdownLinkText": { "dark": "teal", "light": "teal" },
        "markdownCode": { "dark": "green", "light": "green" },
        "markdownBlockQuote": { "dark": "overlay1", "light": "overlay1" },
        "markdownEmph": { "dark": "peach", "light": "peach" },
        "markdownStrong": { "dark": "yellow", "light": "yellow" },
        "markdownHorizontalRule": { "dark": "surface1", "light": "surface1" },
        "markdownListItem": { "dark": "blue", "light": "blue" },
        "markdownListEnumeration": { "dark": "teal", "light": "teal" },
        "markdownImage": { "dark": "lavender", "light": "lavender" },
        "markdownImageText": { "dark": "teal", "light": "teal" },
        "markdownCodeBlock": { "dark": "subtext1", "light": "subtext1" },

        "syntaxComment": { "dark": "overlay1", "light": "overlay1" },
        "syntaxKeyword": { "dark": "mauve", "light": "mauve" },
        "syntaxFunction": { "dark": "blue", "light": "blue" },
        "syntaxVariable": { "dark": "text", "light": "text" },
        "syntaxString": { "dark": "green", "light": "green" },
        "syntaxNumber": { "dark": "peach", "light": "peach" },
        "syntaxType": { "dark": "yellow", "light": "yellow" },
        "syntaxOperator": { "dark": "sky", "light": "sky" },
        "syntaxPunctuation": { "dark": "subtext1", "light": "subtext1" }
    }
}
